{
  "name": "coldstart-mcp",
  "version": "0.1.0",
  "description": "Local MCP server for AI agent codebase navigation — domain mapping, dependency tracing, file structure lookup",
  "type": "module",
  "bin": {
    "coldstart-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "keywords": [
    "mcp",
    "ai",
    "codebase",
    "navigation",
    "agent",
    "dependency",
    "indexer"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AkashGoenka/coldstart"
  },
  "scripts": {
    "build": "tsc --noEmit false",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:patch": "npm run test && npm run build && npm version patch && git push --follow-tags && npm publish",
    "release:minor": "npm run test && npm run build && npm version minor && git push --follow-tags && npm publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "tree-sitter": "^0.21.1",
    "tree-sitter-c-sharp": "^0.21.3",
    "tree-sitter-go": "^0.23.4",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-php": "^0.23.12",
    "tree-sitter-python": "^0.23.4",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=18"
  }
}
