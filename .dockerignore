# Keep `COPY . .` from clobbering the node_modules installed by the preceding
# `npm ci` layer — the single most common way this kind of Dockerfile breaks.
node_modules

# Build output is regenerated by `npm run build` inside the image.
dist

.git
.github

# Per-repo runtime state: cache, keeper lockfiles, and the notebook. Machine- and
# repo-specific, never wanted in an image.
.coldstart
